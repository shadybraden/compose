{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "docker:enableMajor"],
  "commitMessagePrefix": ":rocket:",
  "prConcurrentLimit": 32,
  "packageRules": [
    {
      "updateTypes": ["patch"],
      "commitMessagePrefix": ":adhesive_bandage:"
    },
    {
      "updateTypes": ["major"],
      "commitMessagePrefix": ":boom:"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["searxng/searxng", "docker.io/searxng/searxng"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})(?:-[\\w]+)?$",
      "automerge": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["quay.io/linuxserver.io/jackett"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["docker.n8n.io/n8nio/n8n"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["jgraph/drawio"],
      "automerge": true,
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "matchPackageNames": ["rustmailer/bichon"],
      "matchDatasources": ["docker"],
      "sourceUrl": "https://github.com/rustmailer/bichon"
    },
    {
      "matchPackageNames": ["hugomods/hugo"],
      "matchDatasources": ["docker"],
      "sourceUrl": "https://github.com/gohugoio/hugo"
    },
    {
      "matchPackageNames": ["mongo"],
      "matchDatasources": ["docker"],
      "sourceUrl": "https://www.mongodb.com/docs/manual/release-notes/"
    },
    {
      "matchPackageNames": ["nextcloud"],
      "matchDatasources": ["docker"],
      "sourceUrl": "https://nextcloud.com/changelog/"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["linuxserver/mullvad-browser"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-ls(?<build>\\d+)$"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)compose[^/]*\\.ya?ml$"],
      "matchStrings": [
        "postgres:(?<currentValue>\\d+\\.\\d+-alpine(?<compatibility>\\d+\\.\\d+))"
      ],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)-alpine(?<patch>\\d+)\\.(?<build>\\d+)$"
    }
  ]
}

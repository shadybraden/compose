{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base", "docker:enableMajor"],
  "commitMessagePrefix": ":rocket:",
  "prConcurrentLimit": 32,
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Dockerfile$", "(^|/)Dockerfile\\..*$"],
      "matchStrings": [
        "apk add (?:[a-z0-9@._+-]+ )*(?<depName>[a-z0-9@._+-]+)=(?<currentValue>[a-z0-9._+-]+)"
      ],
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose",
      "registryUrlTemplate": "https://repology.org/api/v1/project/{{depName}}"
    }
  ],
  "packageRules": [
    {
      "updateTypes": ["patch"],
      "commitMessagePrefix": ":adhesive_bandage:"
    },
    {
      "updateTypes": ["major"],
      "commitMessagePrefix": ":boom:"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["searxng/searxng", "docker.io/searxng/searxng"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})(?:-[\\w]+)?$",
      "automerge": true
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["quay.io/linuxserver.io/jackett"],
      "automerge": true
    }
  ]
}
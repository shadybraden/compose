{
    "distSpecVersion": "1.0.1",
    "storage": {
        "rootDirectory": "/tmp/zot"
    },
    "http": {
        "address": "127.0.0.1",
        "port": "5000",
        "accessControl": {
            "groups": {
            "group1": {
                "users": ["bob", "mary"]
            },
            "group2": {
                "users": ["alice", "mallory", "jim"]
            }
            },
            "repositories": {
            "**": {
                "policies": [{
                "users": ["charlie"],
                "groups": ["group2"],
                "actions": ["read", "create", "update"]
                }],
                "defaultPolicy": ["read", "create"]
            },
            "tmp/**": {
                "anonymousPolicy": ["read"],
                "defaultPolicy": ["read", "create", "update"]
            },
            "infra/*": {
                "policies": [{
                    "users": ["alice", "bob"],
                    "actions": ["create", "read", "update", "delete"]
                },
                {
                    "users": ["mallory"],
                    "groups": ["group1"],
                    "actions": ["create", "read"]
                }
                ],
                "defaultPolicy": ["read"]
            },
            "repos2/repo": {
                "policies": [{
                    "users": ["bob"],
                    "actions": ["read", "create"]
                },
                {
                    "users": ["mallory"],
                    "actions": ["create", "read"]
                }
                ],
                "defaultPolicy": ["read"]
            }
            },
            "adminPolicy": {
            "users": ["admin"],
            "actions": ["read", "create", "update", "delete"]
            }
        }
    },
    "log": {
        "level": "debug"
    }
}
